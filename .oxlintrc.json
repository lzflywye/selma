{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "rules": {
    "react/react-in-jsx-scope": "off"
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off"
  },
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "react",
    "nextjs",
    "oxc",
    "jsx-a11y"
  ],
  "env": {
    "builtin": true
  },
  "ignorePatterns": [
    ".next/**",
    "out/**",
    "build/**",
    "next-env.d.ts",
    "components/ui/**"
  ]
}
